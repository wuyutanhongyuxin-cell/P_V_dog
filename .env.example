# ============================
# Paradex 配置
# ============================
PARADEX_L2_PRIVATE_KEY=0x...your_starknet_private_key...
PARADEX_L2_ADDRESS=0x...your_starknet_address...
PARADEX_ENVIRONMENT=prod

# ============================
# Variational 配置
# ============================
# 方式1: Cookie 认证 (推荐)
# 从浏览器 F12 > Application > Cookies 获取
VARIATIONAL_VR_TOKEN=eyJhbGciOiJIUzI1NiIs...
VARIATIONAL_WALLET_ADDRESS=0x...your_ethereum_wallet...
VARIATIONAL_COOKIES=vr-token=eyJ...; cf_clearance=...

# 方式2: SIWE 签名认证
# VARIATIONAL_PRIVATE_KEY=0x...your_ethereum_private_key...

VARIATIONAL_BASE_URL=https://omni.variational.io

# ============================
# Telegram 通知 (可选)
# ============================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_GROUP_ID=-1001234567890
ACCOUNT_LABEL=DCA-1

# ============================
# 可选配置
# ============================
TIMEZONE=Asia/Shanghai
# PARADEX_MARKET=BTC-USD-PERP
# VARIATIONAL_MARKET=BTC
